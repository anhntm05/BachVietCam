# Cong cua API Gateway
PORT=4000

# URL Django AI service (khong co dau / o cuoi)
AI_SERVICE_URL=http://127.0.0.1:8000

# Thu muc dung chung voi Django. De trong thi mac dinh ../shared_storage
SHARED_STORAGE_PATH=

# Timeout goi sang AI service, mili-giay. pYIN cham nen de rong rai.
AI_TIMEOUT_MS=120000

# Nguon (origin) frontend duoc phep goi API. Co direct phan cach boi dau phay neu nhieu url.
CORS_ORIGIN=http://localhost:3000

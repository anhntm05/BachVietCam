# ==============================
ai-service/venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.Python

# Database SQLite (moi nguoi tu tao lai bang migrate)
*.sqlite3
db.sqlite3

# File .env that (chua secret), chi commit .env.example
.env
.env.*
!.env.example

# ==============================
#  Node / Express (api-gateway)
# ==============================
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================
#  Next.js (web-portal)
# ==============================
.next/
out/
next-env.d.ts

# ==============================
#  Du lieu runtime dung chung
# ==============================
# Khong commit file ghi am / mau tam thoi cua nguoi dung,
# nhung giu lai cau truc thu muc bang .gitkeep (xem README).
shared_storage/uploads/*
shared_storage/templates/*
!shared_storage/uploads/.gitkeep
!shared_storage/templates/.gitkeep

